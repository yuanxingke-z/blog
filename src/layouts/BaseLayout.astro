---
import "../styles/global.css";
import { SITE } from "../site.config";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string[];
  type?: "website" | "article";
  publishedTime?: string;
  tags?: string[];
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const pageTitle = Astro.props.title
  ? `${Astro.props.title} · ${SITE.title}`
  : SITE.title;
const description = Astro.props.description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, SITE.url);
const image = new URL(Astro.props.image ?? SITE.defaultImage, SITE.url);
const keywords = Astro.props.keywords?.join(", ");
const type = Astro.props.type ?? "website";
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const webmasterVerifications = [
  ["google-site-verification", import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION],
  ["baidu-site-verification", import.meta.env.PUBLIC_BAIDU_SITE_VERIFICATION],
  ["msvalidate.01", import.meta.env.PUBLIC_BING_SITE_VERIFICATION],
].filter(([, content]) => Boolean(content));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <link rel="alternate" type="application/feed+json" title={SITE.title} href="/feed.json" />
    <link rel="search" type="application/opensearchdescription+xml" title={SITE.title} href="/opensearch.xml" />
    <link rel="canonical" href={canonical} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    {
      webmasterVerifications.map(([name, content]) => (
        <meta name={name} content={content} />
      ))
    }
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    {Astro.props.publishedTime && <meta property="article:published_time" content={Astro.props.publishedTime} />}
    {Astro.props.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
    {
      Astro.props.structuredData && (
        <script type="application/ld+json" set:html={JSON.stringify(Astro.props.structuredData)} />
      )
    }
    {
      umamiSrc && umamiWebsiteId && (
        <script defer src={umamiSrc} data-website-id={umamiWebsiteId}></script>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${SITE.title} 首页`}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span>{SITE.title}</span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        {
          SITE.nav.map((item) => (
            <a href={item.href} class:list={{ active: Astro.url.pathname === item.href }}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} {SITE.author} · 用 Astro 记录平凡日子</p>
      <div class="footer-links">
        <a href="/search/">搜索</a>
        <a href="/rss.xml">RSS</a>
        <a href="/feed.json">JSON Feed</a>
      </div>
    </footer>
  </body>
</html>
