---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Comments from "../../components/Comments.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../site.config";
import { formatDate, getPublishedPosts } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = await getPublishedPosts();
const index = posts.findIndex((item) => item.id === post.id);
const newerPost = index > 0 ? posts[index - 1] : undefined;
const olderPost = index < posts.length - 1 ? posts[index + 1] : undefined;
const relatedPosts = posts
  .filter((item) => item.id !== post.id)
  .map((item) => ({
    post: item,
    score: item.data.tags.filter((tag) => post.data.tags.includes(tag)).length,
  }))
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map((item) => item.post);
const postUrl = new URL(`/posts/${post.id}/`, SITE.url);
const coverUrl = post.data.cover ? new URL(post.data.cover, SITE.url) : undefined;
const encodedUrl = encodeURIComponent(postUrl.toString());
const encodedTitle = encodeURIComponent(post.data.title);
const encodedDescription = encodeURIComponent(post.data.description);
const encodedImage = coverUrl ? encodeURIComponent(coverUrl.toString()) : "";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: post.data.pubDate.toISOString(),
    author: {
      "@type": "Person",
      name: SITE.author,
    },
    publisher: {
      "@type": "Organization",
      name: SITE.title,
    },
    mainEntityOfPage: postUrl.toString(),
    url: postUrl.toString(),
    image: coverUrl?.toString(),
    keywords: post.data.tags.join(", "),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "首页",
        item: SITE.url,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "随笔",
        item: new URL("/posts/", SITE.url).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: post.data.title,
        item: postUrl.toString(),
      },
    ],
  },
  ...(relatedPosts.length
    ? [
        {
          "@context": "https://schema.org",
          "@type": "ItemList",
          name: `${post.data.title} 的相关文章`,
          itemListElement: relatedPosts.map((relatedPost, relatedIndex) => ({
            "@type": "ListItem",
            position: relatedIndex + 1,
            name: relatedPost.data.title,
            url: new URL(`/posts/${relatedPost.id}/`, SITE.url).toString(),
          })),
        },
      ]
    : []),
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.cover}
  keywords={post.data.tags}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  tags={post.data.tags}
  structuredData={structuredData}
>
  <article class="article-shell">
    <header class="article-header">
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row">
        {post.data.tags.map((tag) => <a href={`/tags/${tag}/`}>#{tag}</a>)}
      </div>
    </header>

    {
      post.data.cover && (
        <figure class="article-cover">
          <img src={post.data.cover} alt={post.data.coverAlt ?? post.data.title} />
        </figure>
      )
    }

    <div class="prose">
      <Content />
    </div>

    <aside class="share-box" aria-labelledby="share-title">
      <div>
        <h2 id="share-title">觉得有点意思？</h2>
        <p>顺手分享给同样想搭个人博客、或者正在和配置文件对视的人。</p>
      </div>
      <div class="share-actions">
        <a href={`https://service.weibo.com/share/share.php?url=${encodedUrl}&title=${encodedTitle}&pic=${encodedImage}`} target="_blank" rel="noopener noreferrer">微博</a>
        <a href={`https://connect.qq.com/widget/shareqq/index.html?url=${encodedUrl}&title=${encodedTitle}&summary=${encodedDescription}&pics=${encodedImage}`} target="_blank" rel="noopener noreferrer">QQ</a>
        <a href={`https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer">Telegram</a>
        <a href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer">X</a>
        <button type="button" data-copy-url={postUrl.toString()}>复制链接</button>
      </div>
    </aside>

    <script>
      document.querySelectorAll("[data-copy-url]").forEach((button) => {
        button.addEventListener("click", async () => {
          const url = button.getAttribute("data-copy-url");
          if (!url) return;
          if (navigator.clipboard) {
            await navigator.clipboard.writeText(url);
          } else {
            const input = document.createElement("input");
            input.value = url;
            document.body.append(input);
            input.select();
            document.execCommand("copy");
            input.remove();
          }
          button.textContent = "已复制";
          window.setTimeout(() => {
            button.textContent = "复制链接";
          }, 1800);
        });
      });
    </script>

    <Comments path={`/posts/${post.id}/`} />

    {
      relatedPosts.length > 0 && (
        <aside class="related-posts" aria-labelledby="related-title">
          <div class="section-head">
            <div>
              <span class="section-kicker">Related</span>
              <h2 id="related-title">继续读点相近的</h2>
            </div>
            <a class="text-link" href="/posts/">全部随笔</a>
          </div>
          <div class="related-grid">
            {relatedPosts.map((relatedPost) => (
              <a class="related-card" href={`/posts/${relatedPost.id}/`}>
                <time datetime={relatedPost.data.pubDate.toISOString()}>{formatDate(relatedPost.data.pubDate)}</time>
                <h3>{relatedPost.data.title}</h3>
                <p>{relatedPost.data.description}</p>
              </a>
            ))}
          </div>
        </aside>
      )
    }

    <nav class="post-nav" aria-label="文章导航">
      {newerPost ? <a href={`/posts/${newerPost.id}/`}><span>上一篇</span>{newerPost.data.title}</a> : <span></span>}
      {olderPost ? <a href={`/posts/${olderPost.id}/`}><span>下一篇</span>{olderPost.data.title}</a> : <span></span>}
    </nav>
  </article>
</BaseLayout>
