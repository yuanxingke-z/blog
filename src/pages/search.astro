---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
const searchIndex = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  url: `/posts/${post.id}/`,
  pubDate: post.data.pubDate.toISOString(),
}));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SearchResultsPage",
  name: "站内搜索",
  description: "搜索小周zh的港湾里发布的随笔、建站记录和程序员日常。",
};
---

<BaseLayout
  title="搜索"
  description="搜索小周zh的港湾里发布的随笔、建站记录和程序员日常。"
  keywords={["站内搜索", "个人博客", "建站记录", "程序员随笔"]}
  structuredData={structuredData}
>
  <section class="container page-hero">
    <span class="section-kicker">Search</span>
    <h1 class="page-title">搜索</h1>
    <p>按标题、摘要或标签找到想看的内容。</p>
  </section>

  <section class="container section search-shell" aria-labelledby="search-title">
    <h2 id="search-title" class="visually-hidden">站内搜索</h2>
    <label class="search-box">
      <span>关键词</span>
      <input id="search-input" type="search" autocomplete="off" placeholder="例如：Astro、建站、评论系统" />
    </label>
    <p id="search-count" class="search-count">输入关键词开始搜索。</p>
    <div id="search-results" class="search-results" aria-live="polite"></div>
  </section>

  <script id="search-index" type="application/json" set:html={JSON.stringify(searchIndex)} />
  <script>
    const input = document.querySelector("#search-input");
    const count = document.querySelector("#search-count");
    const results = document.querySelector("#search-results");
    const indexElement = document.querySelector("#search-index");
    const posts = JSON.parse(indexElement?.textContent || "[]");
    const formatter = new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });

    function escapeHtml(value) {
      return value.replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[char]);
    }

    function render(items) {
      if (!results || !count) return;
      count.textContent = items.length ? `找到 ${items.length} 篇相关内容。` : "没有找到匹配内容。";
      results.innerHTML = items
        .map((post) => `
          <a class="search-result" href="${post.url}">
            <time datetime="${post.pubDate}">${formatter.format(new Date(post.pubDate))}</time>
            <h3>${escapeHtml(post.title)}</h3>
            <p>${escapeHtml(post.description)}</p>
            <span>${post.tags.map((tag) => `#${escapeHtml(tag)}`).join(" ")}</span>
          </a>
        `)
        .join("");
    }

    input?.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      if (!query) {
        if (count) count.textContent = "输入关键词开始搜索。";
        if (results) results.innerHTML = "";
        return;
      }
      render(posts.filter((post) => {
        const text = [post.title, post.description, ...post.tags].join(" ").toLowerCase();
        return query.split(/\s+/).every((word) => text.includes(word));
      }));
    });

    const initialQuery = new URLSearchParams(window.location.search).get("q");
    if (input && initialQuery) {
      input.value = initialQuery;
      input.dispatchEvent(new Event("input"));
    }
  </script>
</BaseLayout>
