---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../site.config";
import { getAllTags, getPublishedPosts } from "../../utils/posts";
import { getTagDescription } from "../../utils/tags";

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "标签",
  description: "按主题浏览小周zh个人博客的所有随笔标签。",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: tags.map((tag, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: `#${tag}`,
      description: getTagDescription(tag),
      url: new URL(`/tags/${tag}/`, SITE.url).toString(),
    })),
  },
};
---

<BaseLayout
  title="标签"
  description="按主题浏览小周zh个人博客的所有随笔标签。"
  keywords={["个人博客标签", "建站", "程序员", "生活随笔"]}
  structuredData={structuredData}
>
  <section class="container page-hero">
    <span class="section-kicker">Tags</span>
    <h1 class="page-title">标签</h1>
    <p>每个标签都是一条小径，通向某一类反复出现的心情和场景。</p>
  </section>

  <section class="container section">
    <div class="tag-cloud">
      {
        tags.map((tag) => {
          const count = posts.filter((post) => post.data.tags.includes(tag)).length;
          return (
            <a href={`/tags/${tag}/`} title={getTagDescription(tag)}>
              #{tag} · {count}
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
