---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { SITE } from "../site.config";
import { getAllTags, getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 3);
const tags = getAllTags(posts).slice(0, 8);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.title,
    url: SITE.url,
    description: SITE.description,
    inLanguage: "zh-CN",
    publisher: {
      "@type": "Person",
      name: SITE.author,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.author,
    url: SITE.url,
    description: "记录程序员日常、个人建站、AI 辅助编程、阅读与生活随笔。",
  },
];
---

<BaseLayout
  description={SITE.description}
  keywords={["个人博客", "程序员博客", "个人建站", "AI 辅助编程", "Astro 博客", "生活随笔"]}
  structuredData={structuredData}
>
  <section class="hero">
    <div>
      <span class="hero-kicker">程序员日常 / 个人建站 / 生活随笔</span>
      <h1>把折腾过的日子写清楚一点。</h1>
      <p>
        这里记录一个程序员的个人博客建站、AI 辅助编程、日常观察和生活随笔。
        偶尔写技术，常常写人间，尽量把踩过的坑和笑过的场都留下。
      </p>
    </div>
    <aside class="hero-panel" aria-label="站点简介">
      <h2>最近在写</h2>
      <p>
        从搭建个人博客开始，记录域名、托管、评论系统、国内外访问分流，以及那些被配置文件按在椅子上的夜晚。
      </p>
    </aside>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <span class="section-kicker">精选</span>
        <h2>近期随笔</h2>
      </div>
      <a class="text-link" href="/posts/">查看全部</a>
    </div>
    <div class="post-grid">
      {featuredPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <span class="section-kicker">索引</span>
        <h2>按标签散步</h2>
      </div>
      <a class="text-link" href="/tags/">全部标签</a>
    </div>
    <div class="tag-cloud">
      {tags.map((tag) => <a href={`/tags/${tag}/`}>#{tag}</a>)}
    </div>
  </section>

  <section class="container section subscribe-band" aria-labelledby="subscribe-title">
    <div>
      <span class="section-kicker">订阅</span>
      <h2 id="subscribe-title">下次更新，不必靠缘分。</h2>
      <p>通过 RSS 订阅新文章，或者把这篇小站丢进书签栏，让它偶尔冒个泡。</p>
    </div>
    <a class="text-link" href="/rss.xml">订阅 RSS</a>
  </section>
</BaseLayout>
