---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { SITE } from "../site.config";
import { getAllTags, getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
const recentPosts = posts.slice(0, 3);
const tags = getAllTags(posts).slice(0, 8);
const postItems = posts.slice(0, 10).map((post, index) => ({
  "@type": "ListItem",
  position: index + 1,
  url: new URL(`/posts/${post.id}/`, SITE.url).toString(),
  name: post.data.title,
  description: post.data.description,
}));
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.title,
    url: SITE.url,
    description: SITE.description,
    inLanguage: "zh-CN",
    publisher: {
      "@type": "Person",
      name: SITE.author,
    },
    potentialAction: {
      "@type": "SearchAction",
      target: `${SITE.url}/search/?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.author,
    url: SITE.url,
    description: "记录程序员日常、个人建站、AI 辅助编程、阅读与生活随笔。",
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: `${SITE.title} 最新文章`,
    itemListElement: postItems,
  },
];
---

<BaseLayout
  description={SITE.description}
  keywords={["个人博客", "程序员博客", "个人建站", "AI 辅助编程", "Astro 博客", "生活随笔"]}
  structuredData={structuredData}
>
  <section class="hero">
    <div class="hero-copy">
      <span class="hero-kicker">程序员日常 / 个人建站 / 生活随笔</span>
      <h1>把折腾过的日子写清楚一点。</h1>
      <p>
        这里记录一个程序员的个人博客建站、AI 辅助编程、日常观察和生活随笔。
        偶尔写技术，常常写人间，尽量把踩过的坑和笑过的场都留下。
      </p>
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <span class="section-kicker">精选</span>
        <h2>近期随笔</h2>
      </div>
      <a class="text-link" href="/posts/">查看全部</a>
    </div>
    <div class="post-grid">
      {recentPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <span class="section-kicker">索引</span>
        <h2>按标签散步</h2>
      </div>
      <a class="text-link" href="/tags/">全部标签</a>
    </div>
    <div class="tag-cloud">
      {tags.map((tag) => <a href={`/tags/${tag}/`}>#{tag}</a>)}
    </div>
  </section>

  <section class="container section subscribe-band" aria-labelledby="subscribe-title">
    <div>
      <span class="section-kicker">订阅</span>
      <h2 id="subscribe-title">下次更新，不必靠缘分。</h2>
      <p>通过 RSS 订阅新文章，或者把这篇小站丢进书签栏，让它偶尔冒个泡。</p>
    </div>
    <a class="text-link" href="/rss.xml">订阅 RSS</a>
  </section>
</BaseLayout>
