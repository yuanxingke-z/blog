---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { SITE } from "../site.config";
import { getAllTags, getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 3);
const tags = getAllTags(posts).slice(0, 8);
---

<BaseLayout description={SITE.description}>
  <section class="hero">
    <div>
      <span class="hero-kicker">生活随笔 / 慢慢记录</span>
      <h1>把日子写得清楚一点。</h1>
      <p>
        这里收藏一些日常里的微光：清晨的街道、雨天的书页、整理过的书桌，
        以及那些暂时不需要变成答案的感受。
      </p>
    </div>
    <aside class="hero-panel" aria-label="站点简介">
      <h2>最近的心情</h2>
      <p>
        写作像给生活留一盏小灯。它不急着照亮远方，只是让今天的轮廓更柔和一些。
      </p>
    </aside>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <span class="section-kicker">精选</span>
        <h2>近期随笔</h2>
      </div>
      <a class="text-link" href="/posts/">查看全部</a>
    </div>
    <div class="post-grid">
      {featuredPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <span class="section-kicker">索引</span>
        <h2>按标签散步</h2>
      </div>
      <a class="text-link" href="/tags/">全部标签</a>
    </div>
    <div class="tag-cloud">
      {tags.map((tag) => <a href={`/tags/${tag}/`}>#{tag}</a>)}
    </div>
  </section>
</BaseLayout>
